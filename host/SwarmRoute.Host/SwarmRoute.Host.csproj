<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DotNetCore.CAP" Version="10.0.1" />
    <PackageReference Include="Hangfire.AspNetCore" Version="1.8.23" />
    <PackageReference Include="Hangfire.PostgreSql" Version="1.21.1" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.9" />
    <PackageReference Include="OpenTelemetry.Exporter.Prometheus.AspNetCore" Version="1.16.0-beta.1" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.16.0" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" Version="1.15.2" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Runtime" Version="1.15.1" />
  </ItemGroup>

  <ItemGroup>
    <!-- Context composition roots (each context's *NativeInjectorBootStrapper). -->
    <ProjectReference Include="..\..\Map\SwarmRoute.Map.Infra.CrossCutting.IoC\SwarmRoute.Map.Infra.CrossCutting.IoC.csproj" />
    <ProjectReference Include="..\..\PathPlanning\SwarmRoute.PathPlanning.Infra.CrossCutting.IoC\SwarmRoute.PathPlanning.Infra.CrossCutting.IoC.csproj" />
    <ProjectReference Include="..\..\TrafficControl\SwarmRoute.TrafficControl.Infra.CrossCutting.IoC\SwarmRoute.TrafficControl.Infra.CrossCutting.IoC.csproj" />
    <ProjectReference Include="..\..\Liveness\SwarmRoute.Liveness.Infra.CrossCutting.IoC\SwarmRoute.Liveness.Infra.CrossCutting.IoC.csproj" />
    <ProjectReference Include="..\..\Coordination\SwarmRoute.Coordination.Application\SwarmRoute.Coordination.Application.csproj" />
    <ProjectReference Include="..\..\Simulation\SwarmRoute.Simulation.Application\SwarmRoute.Simulation.Application.csproj" />
    <ProjectReference Include="..\..\Shared\SwarmRoute.EventBus\SwarmRoute.EventBus.csproj" />

    <!-- Api assemblies so their controllers are discovered as MVC application parts. -->
    <ProjectReference Include="..\..\Map\SwarmRoute.Map.Api\SwarmRoute.Map.Api.csproj" />
    <ProjectReference Include="..\..\TrafficControl\SwarmRoute.TrafficControl.Api\SwarmRoute.TrafficControl.Api.csproj" />

    <!-- Domain/Contract references the Host adapters bind to (Map-backed IResourceTopology + avoidance selector). -->
    <ProjectReference Include="..\..\Map\SwarmRoute.Map.Domain\SwarmRoute.Map.Domain.csproj" />
    <ProjectReference Include="..\..\Map\SwarmRoute.Map.Infra.Data\SwarmRoute.Map.Infra.Data.csproj" />
    <ProjectReference Include="..\..\TrafficControl\SwarmRoute.TrafficControl.Domain\SwarmRoute.TrafficControl.Domain.csproj" />
    <ProjectReference Include="..\..\TrafficControl\SwarmRoute.TrafficControl.Application.Contract\SwarmRoute.TrafficControl.Application.Contract.csproj" />
    <ProjectReference Include="..\..\TrafficControl\SwarmRoute.TrafficControl.Infra.Data\SwarmRoute.TrafficControl.Infra.Data.csproj" />
    <ProjectReference Include="..\..\Liveness\SwarmRoute.Liveness.Domain\SwarmRoute.Liveness.Domain.csproj" />
    <ProjectReference Include="..\..\Liveness\SwarmRoute.Liveness.Application\SwarmRoute.Liveness.Application.csproj" />
  </ItemGroup>

</Project>
